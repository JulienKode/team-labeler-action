{
  "name": "team-labeler-action",
  "version": "2.0.2",
  "private": true,
  "description": "Action to add a label based on the team",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/",
    "package": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "build:pack": "pnpm build && pnpm package",
    "all": "pnpm build && pnpm format && pnpm lint && pnpm package && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JulienKode/team-labeler-action.git"
  },
  "keywords": [
    "actions",
    "github",
    "team",
    "label",
    "labeller",
    "node"
  ],
  "author": "Julien Karst",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@octokit/core>@octokit/types": "13.6.1",
      "@octokit/request>@octokit/types": "13.6.1",
      "@octokit/graphql>@octokit/types": "13.6.1",
      "@octokit/endpoint>@octokit/types": "13.6.1",
      "@octokit/request-error>@octokit/types": "13.6.1"
    }
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/github": "9.0.0",
    "js-yaml": "4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "js-yaml": "4.1.1",
    "prettier": "3.8.3",
    "rollup": "4.60.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "undici": "6.24.0",
    "vitest": "4.1.2"
  }
}
